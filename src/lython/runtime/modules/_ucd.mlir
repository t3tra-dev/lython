    %pool = memref.get_global @__ly_ucd_ext_case : memref<367xi32>
    %raw = memref.load %pool[%slot_index] : memref<367xi32>
    %value = arith.extui %raw : i32 to i64
    func.return %value : i64
  }

  // ASCII byte %j (0/1) of the two-letter name of category enum
  // %cat. An accessor rather than a shared global: cross-module
  // memref.get_global does not verify, function declarations do.
  func.func private @__ly_ucd_category_char(%cat: i64, %j: i64) -> i64 {
    %two = arith.constant 2 : i64
    %base = arith.muli %cat, %two : i64
    %slot = arith.addi %base, %j : i64
    %slot_index = arith.index_cast %slot : i64 to index
    %names = memref.get_global @__ly_ucd_category_names : memref<60xi8>
    %raw = memref.load %names[%slot_index] : memref<60xi8>
    %value = arith.extui %raw : i8 to i64
    func.return %value : i64
  }

  func.func private @__ly_ucd_numeric_value(%idx: i64) -> f64 {
    %idx_index = arith.index_cast %idx : i64 to index
    %pool = memref.get_global @__ly_ucd_numeric_values : memref<142xf64>
    %value = memref.load %pool[%idx_index] : memref<142xf64>
    func.return %value : f64
  }
}
